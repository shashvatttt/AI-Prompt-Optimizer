{
  "manifest_version": 3,
  "name": "AI Prompt Optimizer Pro",
  "version": "1.0.0",
  "description": "Refines and optimizes prompts in real-time inside ChatGPT, Claude, Gemini, DeepSeek, and more using advanced prompt engineering.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://*.deepseek.com/*",
        "https://copilot.microsoft.com/*",
        "https://*.copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
